import types as _types

_W = 58  # menu column width

def _clear():
    os.system("cls" if os.name == "nt" else "clear")

def _hdr(title):
    pad = max(0, _W - len(title) - 4)
    print(f"\n  {C}{B}── {title} {'─' * pad}{NC}\n")

def _ask(prompt, default=None, ex=None):
    """Required input. Shows [default] in brackets and optional example."""
    if ex:
        for line in (ex if isinstance(ex, list) else [ex]):
            print(f"  {B}    e.g. {line}{NC}")
    d = f" [{default}]" if default is not None else ""
    while True:
        v = input(f"  {Y}{prompt}{d}: {NC}").strip()
        if v:           return v
        if default is not None: return str(default)
        print(f"  {R}  required{NC}")

def _opt(prompt, default="", ex=None):
    """Optional input. Enter to keep default or skip."""
    if ex:
        for line in (ex if isinstance(ex, list) else [ex]):
            print(f"  {B}    e.g. {line}{NC}")
    d = f" [{default}]" if default else " (enter to skip)"
    v = input(f"  {Y}{prompt}{d}: {NC}").strip()
    return v if v else default

def _yn(prompt, default=False, note=None):
    if note:
        print(f"  {B}    {note}{NC}")
    hint = "Y/n" if default else "y/N"
    v = input(f"  {Y}{prompt} [{hint}]: {NC}").strip().lower()
    return v in ("y", "yes", "1") if v else default

def _pick(title, items, back=True):
    """
    Numbered menu. items = [(label, desc), ...].
    Returns (index, label), or (-1, None) for back, exits on q.
    """
    while True:
        _clear()
        banner()
        _hdr(title)
        for i, (lbl, desc) in enumerate(items, 1):
            print(f"  {Y}{i:>2}.{NC}  {B}{lbl:<22}{NC} {desc}")
        footer = f"\n   {Y}b.{NC}  back    {Y}q.{NC}  quit\n" if back else f"\n   {Y}q.{NC}  quit\n"
        print(footer)
        raw = input(f"  {C}> {NC}").strip().lower()
        if raw == "q":  sys.exit(0)
        if raw == "b" and back:  return -1, None
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(items):
                return idx, items[idx][0]
        except ValueError:
            pass

def _action(choices=("install", "remove", "status")):
    _hdr("Action")
    for i, c in enumerate(choices, 1):
        print(f"  {Y}{i}.{NC}  {c}")
    print()
    while True:
        raw = input(f"  {C}> {NC}").strip()
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(choices):
                return choices[idx]
        except ValueError:
            if raw in choices:
                return raw
        print(f"  {R}  pick 1-{len(choices)}{NC}")

def _confirm(lines):
    """Print summary, return True to run, False to go back."""
    _clear()
    banner()
    _hdr("Summary")
    for l in lines:
        print(f"  {l}")
    print(f"\n  {G}r.{NC} run    {Y}b.{NC} back    {Y}q.{NC} quit\n")
    while True:
        raw = input(f"  {C}> {NC}").strip().lower()
        if raw == "r":  return True
        if raw == "b":  return False
        if raw == "q":  sys.exit(0)

def _pause():
    input(f"\n  {Y}press enter to continue...{NC}")

# ── target + connection prompt ─────────────────────────────────────────────────

def _prompt_target():
    """Prompt for target mode + SSH connection. Returns SimpleNamespace or None."""
    mode_idx, _ = _pick("Target Mode", [
        ("single",       "enter USER@HOST directly"),
        ("named hosts",  "pick from the built-in host list"),
        ("all hosts",    f"all {len(LINUX_HOSTS)} Linux hosts"),
    ])
    if mode_idx == -1:
        return None

    ns = _types.SimpleNamespace(
        target=None, named_hosts=None, all_hosts=False,
        user="root", ssh_pass="", identity="", port="22",
        sudo_pass="", no_sudo=False, jobs=None, dry_run=False, verbose=False,
    )

    _clear(); banner()

    if mode_idx == 0:
        _hdr("Single Target")
        ns.target = _ask("USER@HOST",
            ex=["root@10.10.10.101", "ubuntu@10.10.10.103  (non-root, will sudo)"])

    elif mode_idx == 1:
        _hdr("Named Hosts  (enter space-separated numbers)")
        host_list = list(LINUX_HOSTS.items())
        for i, (name, ip) in enumerate(host_list, 1):
            print(f"  {Y}{i:>2}.{NC}  {B}{name:<22}{NC} {ip}")
        print(f"\n  {B}    e.g. 1          (just ftp)   |   1 3 5   (ftp + db + samba)   |   1-9 all{NC}\n")
        while True:
            raw = input(f"  {C}> {NC}").strip()
            if not raw:
                print(f"  {R}  select at least one{NC}"); continue
            try:
                idxs = [int(x) - 1 for x in raw.split()]
                if all(0 <= i < len(host_list) for i in idxs):
                    ns.named_hosts = [host_list[i][0] for i in idxs]
                    break
                print(f"  {R}  out of range{NC}")
            except ValueError:
                print(f"  {R}  numbers only{NC}")

    else:
        ns.all_hosts = True

    _hdr("SSH Connection")
    ns.user      = _opt("SSH user", "root",
        ex="ubuntu  (if not already root; sudo will be used)")
    ns.ssh_pass  = _opt("SSH password",
        ex=["hunter2", "P@ssw0rd!  (leave blank to use key auth)"])
    ns.identity  = _opt("SSH key file",
        ex=["~/.ssh/id_ed25519", "~/.rt_keys/rt.key  (leave blank if using password)"])
    ns.port      = _opt("SSH port", "22",
        ex="2222  (non-standard port)")
    ns.sudo_pass = _opt("Sudo password",
        ex="leave blank to use same password as SSH login")
    ns.no_sudo   = _yn("Skip sudo (already SSH'd as root)?", False,
        note="set yes if you SSH'd directly as root (--no-sudo flag)")
    if mode_idx > 0:
        jobs_raw   = _opt("Parallel jobs", "9",
            ex="4  (limit concurrency on slow networks)")
        ns.jobs    = int(jobs_raw) if jobs_raw.isdigit() else None
        ns.dry_run = _yn("Dry run?", False,
            note="prints the mass-deploy command per host without executing it")
    ns.verbose   = _yn("Verbose?", False,
        note="shows the full remote bash command before it runs on each target")
    return ns

