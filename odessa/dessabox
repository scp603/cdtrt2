def run(cmd, *, check=False):
    """Execute a command list, inheriting stdio."""
    return subprocess.run(cmd, check=check)

def script(rel_path, *args, sudo=False):
    """Build a command list for a toolkit script."""
    full = os.path.join(TOOL_DIR, rel_path)
    if not os.path.isfile(full):
        print(f"{R}[!]{NC} script not found: {full}")
        sys.exit(1)
    cmd = ["sudo", "bash", full, *args] if sudo else ["bash", full, *args]
    return cmd

