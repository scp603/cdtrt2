def main():
    # No args -> interactive menu
    if len(sys.argv) == 1:
        try:
            menu_main()
        except KeyboardInterrupt:
            print(f"\n\n  {Y}ctrl-c — bye{NC}\n")
        sys.exit(0)

    parser = argparse.ArgumentParser(
        prog="dessabox",
        description=f"{B}dessabox{NC} -odessa red team toolkit",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"  Run {Y}dessabox info tools{NC} to see the full tool map.\n"
               f"  Run {Y}dessabox <category> --help{NC} for subcommand details."
    )
    parser.add_argument("--no-banner", action="store_true", help="suppress banner")

    subs = parser.add_subparsers(dest="category", metavar="CATEGORY")
    add_persist(subs)
    add_deploy(subs)
    add_sabotage(subs)
    add_webshell(subs)
    add_net(subs)
    add_chaos(subs)
    add_info(subs)

    args = parser.parse_args()

    if args.category is None:
        banner()
        parser.print_help()
        sys.exit(0)

    if not hasattr(args, "func"):
        parser.parse_args([args.category, "--help"])
        sys.exit(1)

    args.func(args)


if __name__ == "__main__":
    main()
