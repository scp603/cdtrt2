def _add_conn(p):
    """Add shared targeting + SSH connection flags to a deploy subparser."""
    tgt = p.add_argument_group("target (pick one)")
    tgt.add_argument("-t", "--target", metavar="USER@HOST",
        help="single arbitrary SSH target")
    tgt.add_argument("--host", dest="named_hosts", metavar="NAME",
        action="append",
        help=f"named host (repeatable).\n{_HOST_HELP}")
    tgt.add_argument("--all", dest="all_hosts", action="store_true",
        help="all Linux hosts in the built-in list")

    conn = p.add_argument_group("SSH connection")
    conn.add_argument("-u", "--user", default="root", metavar="USER",
        help="SSH username (host/all mode, default: root)")
    conn.add_argument("-p", "--pass", dest="ssh_pass", metavar="PASS")
    conn.add_argument("-i", "--identity", metavar="FILE",
        help="SSH private key file")
    conn.add_argument("-P", "--port", default="22", metavar="PORT")
    conn.add_argument("-S", "--sudo-pass", dest="sudo_pass", metavar="PASS")
    conn.add_argument("--no-sudo", action="store_true",
        help="skip sudo (already SSH'd as root)")
    conn.add_argument("-j", "--jobs", type=int, metavar="N",
        help="max parallel jobs (host/all mode, default: 9)")
    conn.add_argument("--dry-run", action="store_true",
        help="print commands without running (host/all mode)")
    conn.add_argument("-v", "--verbose", action="store_true")


def _dispatch(args, tool_name, tool_args):
    """Route attack to rt-ssh.sh (single) or mass-deploy.sh (multi)."""
    import tempfile

    modes = sum([
        bool(args.target),
        bool(args.named_hosts),
        bool(args.all_hosts),
    ])
    if modes == 0:
        print(f"{R}[!]{NC} specify a target: --target USER@HOST  |  --host NAME  |  --all")
        sys.exit(1)
    if modes > 1:
        print(f"{R}[!]{NC} --target, --host, and --all are mutually exclusive")
        sys.exit(1)

    # ── validate named hosts ──────────────────────────────────────────────────
    if args.named_hosts:
        for h in args.named_hosts:
            if h not in LINUX_HOSTS:
                print(f"{R}[!]{NC} unknown host '{h}'.  Known: {', '.join(LINUX_HOSTS)}")
                sys.exit(1)

    # ── single target via rt-ssh.sh ───────────────────────────────────────────
    if args.target:
        cmd = ["bash", os.path.join(TOOL_DIR, "rt-ssh.sh"),
               "-t", args.target]
        if args.ssh_pass:  cmd += ["-p", args.ssh_pass]
        if args.identity:  cmd += ["-i", args.identity]
        if args.port != "22": cmd += ["-P", args.port]
        if args.sudo_pass: cmd += ["-S", args.sudo_pass]
        if args.no_sudo:   cmd += ["--no-sudo"]
        if args.verbose:   cmd += ["-v"]
        cmd += [tool_name] + tool_args
        run(cmd)
        return

    # ── mass-deploy.sh (named hosts or all) ──────────────────────────────────
    mass_cmd = ["bash", os.path.join(TOOL_DIR, "mass-deploy.sh")]
    if args.user != "root":  mass_cmd += ["-u", args.user]
    if args.ssh_pass:        mass_cmd += ["-p", args.ssh_pass]
    if args.identity:        mass_cmd += ["-i", args.identity]
    if args.port != "22":    mass_cmd += ["-P", args.port]
    if args.sudo_pass:       mass_cmd += ["-S", args.sudo_pass]
    if args.no_sudo:         mass_cmd += ["--no-sudo"]
    if args.jobs:            mass_cmd += ["-j", str(args.jobs)]
    if args.dry_run:         mass_cmd += ["--dry-run"]
    if args.verbose:         mass_cmd += ["-v"]

    if args.named_hosts:
        ips = [LINUX_HOSTS[h] for h in args.named_hosts]
        with tempfile.NamedTemporaryFile(mode="w", suffix=".hosts", delete=False) as f:
            f.write("\n".join(ips) + "\n")
            tmp = f.name
        print(f"{G}[+]{NC} targeting {len(ips)} host(s): {', '.join(args.named_hosts)}")
        try:
            run(mass_cmd + ["--hosts", tmp] + [tool_name] + tool_args)
        finally:
            os.unlink(tmp)
    else:
        print(f"{G}[+]{NC} targeting all {len(LINUX_HOSTS)} Linux hosts")
        run(mass_cmd + [tool_name] + tool_args)


